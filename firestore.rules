
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for userInfo collection
    match /userInfo/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Rules for user-specific data
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
    
    // Allow public read for learning materials
    match /englishWords/{wordId} { allow read: if true; allow write: if false; }
    match /japaneseWords/{wordId} { allow read: if true; allow write: if false; }
    match /englishGrammar/{ruleId} { allow read: if true; allow write: if false; }
    match /japaneseGrammar/{ruleId} { allow read: if true; allow write: if false; }
    match /hiragana/{kanaId} { allow read: if true; allow write: if false; }
    match /katakana/{kanaId} { allow read: if true; allow write: if false; }
    match /programmingConcepts/{conceptId} { allow read: if true; allow write: if false; }
    match /cheatSheetItems/{itemId} { allow read: if true; allow write: if false; }
    match /progressItems/{itemId} { allow read: if true; allow write: if false; }
  }
}
