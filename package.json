{
  "name": "my-web-workspace",
  "version": "0.1.0",
  "private": true,
  "nx": {},
  "scripts": {
    "dev": "nx serve nextn",
    "build": "nx build nextn",
    "build:static": "STATIC_EXPORT=true nx build nextn",
    "start": "nx serve nextn --prod",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "deploy": "nx deploy nextn",
    "genkit:dev": "genkit start -- tsx apps/nextn/src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch apps/nextn/src/ai/dev.ts",
    "cap:init": "npx cap init",
    "cap:add:android": "npx cap add android",
    "cap:sync": "nx cap:sync nextn",
    "cap:open:android": "nx cap:open:android nextn",
    "cap:build": "nx build nextn && npx cap sync",
    "apk:build": "nx apk:build nextn",
    "apk:release": "nx apk:release nextn",
    "nx:graph": "nx graph",
    "nx:affected": "nx affected:build"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
