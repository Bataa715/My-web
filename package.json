    "framer-motion": "^12.38.0",
    "genkit": "^1.20.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
