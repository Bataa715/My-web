
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "bio": {
          "type": "string",
          "description": "A short biography of the user."
        },
        "profileImage": {
          "type": "string",
          "description": "URL of the user's profile image."
        },
        "orbitInfo": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "icon": { "type": "string" },
              "title": { "type": "string" },
              "content": { "type": "string" },
              "type": { "type": "string" },
              "backgroundImage": { "type": "string" },
              "youtubeVideoId": { "type": "string" }
            },
            "required": ["id", "icon", "title", "content"]
          }
        },
        "github": {
          "type": "string",
          "description": "URL of the user's GitHub profile."
        },
        "instagram": {
          "type": "string",
          "description": "URL of the user's Instagram profile."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "homeHeroImage": {
            "type": "string",
            "description": "URL of the hero image for the home page."
        },
        "aboutHeroImage": {
            "type": "string",
            "description": "URL of the hero image for the about page."
        },
        "toolsHeroImage": {
            "type": "string",
            "description": "URL of the hero image for the tools page."
        }
      },
      "required": ["name", "bio"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a project in the portfolio.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "technologies": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "link": { "type": "string" },
        "live": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "technologies", "category", "createdAt"]
    },
    "Skill": {
      "title": "Skill",
      "description": "Represents a skill category and a list of skills within it.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "icon", "items", "createdAt"]
    },
    "EnglishWord": {
      "title": "English Word",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "translation": { "type": "string" },
        "definition": { "type": "string" },
        "memorized": { "type": "boolean" },
        "favorite": { "type": "boolean" }
      },
      "required": ["word", "translation"]
    },
    "JapaneseWord": {
      "title": "Japanese Word",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "romaji": { "type": "string" },
        "meaning": { "type": "string" },
        "memorized": { "type": "boolean" },
        "favorite": { "type": "boolean" }
      },
      "required": ["word", "romaji", "meaning"]
    },
    "GrammarRule": {
      "title": "Grammar Rule",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "explanation": { "type": "string" },
        "examples": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "explanation"]
    },
    "ReadingMaterial": {
      "title": "Reading Material",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "Kana": {
      "title": "Kana",
      "type": "object",
      "properties": {
        "character": { "type": "string" },
        "romaji": { "type": "string" }
      },
      "required": ["character", "romaji"]
    },
    "ProgrammingConcept": {
      "title": "Programming Concept",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "emoji": { "type": "string" },
        "explanation": { "type": "string" }
      },
      "required": ["title", "emoji", "explanation"]
    },
    "CheatSheetItem": {
      "title": "Cheat Sheet Item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "snippet": { "type": "string" }
      },
      "required": ["title", "snippet"]
    },
    "ProgressItem": {
      "title": "Progress Item",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "learned": { "type": "boolean" },
        "practicing": { "type": "boolean" }
      },
      "required": ["label", "learned", "practicing"]
    },
    "MemorizedKana": {
        "title": "Memorized Kana",
        "type": "object",
        "properties": {
            "characters": { "type": "array", "items": { "type": "string" } }
        }
    },
    "ProgrammingProgress": {
        "title": "Programming Progress",
        "type": "object",
        "properties": {
            "items": { "type": "object" }
        }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores user projects."
    },
    "/users/{userId}/skills/{skillId}": {
      "schema": { "$ref": "#/entities/Skill" },
      "description": "Stores user skills."
    },
     "/users/{userId}/englishWords/{wordId}": {
      "schema": { "$ref": "#/entities/EnglishWord" }
    },
    "/users/{userId}/japaneseWords/{wordId}": {
      "schema": { "$ref": "#/entities/JapaneseWord" }
    },
     "/users/{userId}/memorized/{kanaType}": {
      "schema": { "$ref": "#/entities/MemorizedKana" }
    },
    "/users/{userId}/progress/{progressType}": {
      "schema": { "$ref": "#/entities/ProgrammingProgress" }
    },
    "/englishWords/{wordId}": { "schema": { "$ref": "#/entities/EnglishWord" } },
    "/japaneseWords/{wordId}": { "schema": { "$ref": "#/entities/JapaneseWord" } },
    "/englishGrammar/{ruleId}": { "schema": { "$ref": "#/entities/GrammarRule" } },
    "/japaneseGrammar/{ruleId}": { "schema": { "$ref": "#/entities/GrammarRule" } },
    "/englishReading/{materialId}": { "schema": { "$ref": "#/entities/ReadingMaterial" } },
    "/englishListening/{materialId}": { "schema": { "$ref": "#/entities/ReadingMaterial" } },
    "/englishSpeaking/{materialId}": { "schema": { "$ref": "#/entities/ReadingMaterial" } },
    "/englishWriting/{materialId}": { "schema": { "$ref": "#/entities/ReadingMaterial" } },
    "/hiragana/{kanaId}": { "schema": { "$ref": "#/entities/Kana" } },
    "/katakana/{kanaId}": { "schema": { "$ref": "#/entities/Kana" } },
    "/programmingConcepts/{conceptId}": { "schema": { "$ref": "#/entities/ProgrammingConcept" } },
    "/cheatSheetItems/{itemId}": { "schema": { "$ref": "#/entities/CheatSheetItem" } },
    "/progressItems/{itemId}": { "schema": { "$ref": "#/entities/ProgressItem" } }
  }
}
