
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "bio": {
          "type": "string",
          "description": "A short biography of the user."
        },
        "profileImage": {
          "type": "string",
          "description": "URL of the user's profile image."
        },
        "orbitInfo": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "icon": { "type": "string" },
              "title": { "type": "string" },
              "content": { "type": "string" },
              "type": { "type": "string" },
              "backgroundImage": { "type": "string" },
              "youtubeVideoId": { "type": "string" }
            },
            "required": ["id", "icon", "title", "content"]
          }
        }
      },
      "required": ["name", "bio"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a project in the portfolio.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the project."
        },
        "description": {
          "type": "string",
          "description": "A description of the project."
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of technologies used in the project."
        },
        "category": {
            "type": "string",
            "description": "The category of the project."
        },
        "link": {
          "type": "string",
          "description": "A link to the project."
        },
        "live": {
            "type": "string",
            "description": "A link to the live version of the project."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        }
      },
      "required": [
        "name",
        "description",
        "technologies",
        "category",
        "createdAt"
      ]
    },
    "Skill": {
      "title": "Skill",
      "description": "Represents a skill category and a list of skills within it.",
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "description": "The category of the skills (e.g., 'Programming Languages')."
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of skills in this category."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        }
      },
      "required": [
        "category",
        "skills",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/userInfo/{userId}": {
        "schema": {
            "$ref": "#/entities/UserProfile"
        },
        "description": "Stores user profile information."
    },
    "/users/{userId}/projects/{projectId}": {
        "schema": {
            "$ref": "#/entities/Project"
        },
        "description": "Stores user projects."
    },
    "/users/{userId}/skills/{skillId}": {
        "schema": {
            "$ref": "#/entities/Skill"
        },
        "description": "Stores user skills."
    }
  }
}
