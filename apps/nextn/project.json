{
  "name": "nextn",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/nextn/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "outputPath": "dist/apps/nextn"
      },
      "configurations": {
        "production": {},
        "development": {
          "outputPath": "dist/apps/nextn"
        }
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "nextn:build",
        "dev": true,
        "port": 9002
      },
      "configurations": {
        "development": {
          "buildTarget": "nextn:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "nextn:build:production",
          "dev": false
        }
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "nextn:build:production"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vercel --prod"
      }
    }
  }
}
